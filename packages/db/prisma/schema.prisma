// Single source of truth for the Areté data model.
// Owned by @arete/db — both @arete/webhook and @arete/dashboard import the
// generated client from this package. Do NOT copy this schema elsewhere.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// Which SCM platform an Installation/Repository belongs to. External IDs
/// (GitHub installation ids, GitLab project ids) are only unique *within*
/// a provider, so every lookup must be scoped by this discriminator.
enum ScmProvider {
  github
  gitlab
}

model Installation {
  id                   String       @id @default(uuid())
  provider             ScmProvider
  /// Provider-scoped external id: GitHub App installation id for `github`,
  /// GitLab project id for `gitlab`. Never globally unique on its own.
  externalId           Int
  owner                String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String       @default("trialing")
  planTier             String       @default("trialing")
  usageCount           Int          @default(0)
  createdAt            DateTime     @default(now())
  /// Per-tenant BYO model config ("connect your model"), or null to use the
  /// service default / Ollama safety fallback. Non-secret fields
  /// (provider, model, baseUrl) are plaintext; the API key is stored as
  /// `apiKeyEncrypted` (AES-256-GCM, same scheme as TelemetryConnection
  /// credentials — see telemetry-credentials.ts), never in plaintext.
  /// Shape: { provider, model?, baseUrl?, apiKeyEncrypted? }.
  repositories         Repository[]
  telemetryConnections TelemetryConnection[]
  telemetrySnapshots   TelemetrySnapshotRecord[]
  webhookEndpoints     WebhookEndpoint[]
  modelConnections     ModelConnection[]
  issueContainers      IssueContainer[]
  accessGrants         InstallationAccess[]
  incidents            Incident[]

  @@unique([provider, externalId])
}

model TelemetryConnection {
  id             String       @id @default(uuid())
  installationId String
  /// Telemetry provider name, e.g. "posthog". A plain string (not the
  /// ScmProvider enum) — telemetry providers are an independently growing
  /// set from source-control providers.
  provider       String
  /// Non-secret provider-specific config, e.g. { "project": "production-app" }.
  config         Json
  /// Encrypted (AES-256-GCM, see credentials.ts) JSON blob. Shape is
  /// provider-specific — for v1 (PostHog, API-key only) it is just
  /// { "apiKey": "..." } — a loose shape avoids a schema migration when a
  /// different auth model is added for a future provider.
  credentials    String
  /// "api_key" | "oauth" — which shape `credentials` holds. api_key rows
  /// store { apiKey/secretKey/token: "..." }; oauth rows store
  /// { accessToken, refreshToken, expiresAt, tokenType }.
  authMethod     String       @default("api_key")
  createdAt      DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [id])

  @@unique([installationId, provider])
}

/// A customer's Bring-Your-Own AI model connection, scoped to an Installation
/// (tenant). Resolved at review time so live reviews run on the customer's own
/// model/key instead of a shared default. One row per (installation, provider).
model ModelConnection {
  id             String       @id @default(uuid())
  installationId String
  /// AI model provider name, e.g. "openai", "anthropic", "ollama". A plain
  /// string (not an enum) — the set of supported model providers grows
  /// independently of source-control providers.
  provider       String
  /// The API key, encrypted with the same AES-256-GCM scheme as
  /// TelemetryConnection.credentials (see packages/webhook telemetry/
  /// credentials.ts, TELEMETRY_ENCRYPTION_KEY). Nullable: a local/self-hosted
  /// connection (e.g. an Ollama endpoint) authenticates by baseUrl alone and
  /// carries no key. Never returned by the API and never logged.
  apiKeyEncrypted String?
  /// Model identifier passed through to the provider, e.g. "gpt-4o" or
  /// "claude-opus-4".
  model          String
  /// Optional custom base URL for self-hosted / proxied / Azure-style
  /// deployments. When null the provider's default endpoint is used.
  baseUrl        String?
  createdAt      DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [id])

  @@unique([installationId, provider])
}

/// A persistent Issue Container: the server-side unit the Fix workflow advances
/// through its lifecycle (open -> solution proposed -> approved -> staged). It is
/// tenant-scoped and gate-enforced — POST /staging/send only opens a PR once
/// gates.solutionApprovedAt is set. The dashboard/driver populate it (create /
/// advance / approve); the webhook lane reads it (loadApprovedContainer), always
/// scoped by installationId. Eng1 owns the definition.
model IssueContainer {
  id             String       @id @default(uuid())
  installationId String
  /// Lifecycle state, e.g. "open" | "solution_proposed" | "approved" | "staged".
  state          String       @default("open")
  /// Server-side gates. Shape: { "solutionApprovedAt": ISO8601 | null }. The
  /// technical sign-off that unlocks PR staging.
  gates          Json
  /// PR target repository. Shape: { "owner": "...", "repo": "..." }.
  target         Json
  /// PR metadata. Shape: { "base": "main", "title": "...", "body": "..." }.
  pr             Json
  /// The staged patch files (StagedPatchFile[]) the PR renders — the diff.
  patch          Json
  /// The review findings this container was opened from (informational source
  /// of the proposed fix). Shape: provider-specific finding objects.
  findings       Json
  /// The live fix-drive transcript (SynthStep[]) — real per-stage steps the
  /// console replays for a fix-born container. Null until a fix run writes it;
  /// never synthesized for display (healing-loop spec §4).
  transcript     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  installation   Installation @relation(fields: [installationId], references: [id])

  @@index([installationId])
}

/// One unit of discovered work — the "email" in the Services inbox.
/// kind: "issue" | "opportunity" | "error" | "pr_finding" (later: "campaign")
/// source: "scan" | "review" | "telemetry" (later: "catalog")
/// state: "open" | "fixing" | "staged" | "posted" | "dismissed"
model WorkItem {
  id             String   @id @default(uuid())
  installationId String
  kind           String
  source         String
  title          String
  detail         String
  /// [{ "path": "src/x.ts", "line": 12, "excerpt": "..." }] — REAL refs only.
  evidence       Json
  /// One of the six review dimensions (security, performance, quality,
  /// test_coverage, deployment_safety, business_logic).
  dimension      String
  confidence     Float
  state          String   @default("open")
  /// Dedup key: sha256 of installationId + dimension + sorted evidence paths.
  fingerprint    String
  containerId    String?
  scanRunId      String?
  /// Consecutive fix_failed count for this item's healing runs (Phase 2 Task 6
  /// cooldown). Incremented atomically alongside the `state: "open"` write in
  /// driveFix's fail() path; reset to 0 by a successful drive. Added rather
  /// than derived: each "Fix it" click creates a BRAND NEW IssueContainer
  /// (work-items/[id]/fix route) and IssueContainer carries no back-reference
  /// to the WorkItem that spawned it, so once a retry overwrites
  /// WorkItem.containerId the prior (possibly failed) container becomes
  /// unreachable from here — there is no query that reconstructs "how many
  /// times in a row has this item failed" from existing rows.
  fixFailureCount Int      @default(0)
  /// Timestamp of the most recent fix_failed outcome. Deliberately NOT derived
  /// from `updatedAt`: scan/trigger.ts and review-sync.ts both refresh an
  /// open WorkItem's title/detail/confidence/scanRunId on every re-scan pass
  /// that still matches its fingerprint, which would reset `updatedAt` and
  /// silently corrupt the cooldown clock if that were the timestamp used.
  fixFailureAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([installationId, fingerprint])
  @@index([installationId, state])
}

/// An alert-born incident. Created by the Alertmanager receiver, resolved when
/// the alert clears. One row per (installationId, fingerprint) — Alertmanager
/// re-sends the same firing alert on its repeat interval, and every resend must
/// land on the same row rather than opening a new incident.
model Incident {
  id             String       @id @default(uuid())
  installationId String
  /// Alertmanager's own fingerprint for the alert instance. The idempotency key.
  fingerprint    String
  alertName      String
  severity       String       /// "critical" | "warning"
  /// "firing" | "resolved"
  status         String       @default("firing")
  summary        String
  /// Alert labels + annotations as received. Scrubbed before write (Task 3).
  payload        Json
  startsAt       DateTime
  resolvedAt     DateTime?
  /// Set when this incident opened a fix run. Null if it never did.
  workItemId     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  installation   Installation @relation(fields: [installationId], references: [id])

  @@unique([installationId, fingerprint])
  @@index([installationId, status])
}

/// One scan execution — honest status, always recorded.
/// status: "running" | "complete" | "failed" | "no_findings"
model ScanRun {
  id             String    @id @default(uuid())
  installationId String
  repositoryId   String
  status         String    @default("running")
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([installationId, startedAt])
}

/// One turn (user message or agent reply) in a specialist agent's chat
/// (packages/dashboard /api/agents/[id]/chat). Solution-scoped: containerId
/// ties a thread to the specific IssueContainer/problem it was opened for —
/// switching to a different work item starts a fresh thread for the same
/// agent. containerId is null for the "general" thread (no work item open).
/// A plain scoping column (installationId, containerId — no @relation),
/// mirroring WorkItem/ScanRun: high-volume, append-only, no need to traverse
/// from Installation/IssueContainer.
model AgentChatTurn {
  id             String   @id @default(uuid())
  installationId String
  /// Matches an Agent.id from the dashboard's agent catalog, e.g. "security".
  agentId        String
  containerId    String?
  /// "user" | "agent"
  role           String
  text           String
  createdAt      DateTime @default(now())

  @@index([installationId, agentId, containerId, createdAt])
}

model Repository {
  id             String       @id @default(uuid())
  provider       ScmProvider
  /// Provider-scoped external id: GitHub repository id or GitLab project id.
  externalId     Int
  name           String
  fullName       String
  installationId String
  createdAt      DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [id])
  reviews        Review[]
  agentMemories  AgentMemory[]

  @@unique([provider, externalId])
}

model Review {
  id             String          @id @default(uuid())
  prNumber       Int
  repositoryId   String
  riskLevel      String
  overallSummary String
  /// Head commit SHA the review was produced for; part of the idempotency key.
  headSha        String
  /// "complete" | "failed" — mirrors ReviewResult.analysis_status.
  analysisStatus String          @default("complete")
  /// Per-specialist tiered-comms status (ReviewResult.agent_statuses):
  /// AgentStatus[] { agent, status, summary, confidence, blockers[] }. Real run
  /// state only — empty/absent when the agents emitted none (never synthesized).
  agentStatuses  Json?
  createdAt      DateTime        @default(now())
  repository     Repository      @relation(fields: [repositoryId], references: [id])
  comments       ReviewComment[]
  approvalPrompts ApprovalPrompt[]

  @@unique([repositoryId, prNumber, headSha])
  @@index([repositoryId, createdAt])
}

model ReviewComment {
  id               String   @id @default(uuid())
  reviewId         String
  path             String
  line             Int
  body             String
  severity         String
  category         String
  
  // Noise Classification Fields
  noiseState       String   @default("OPEN") // "OPEN", "SILENCED", "UNDER_OBSERVATION", "ESCALATED"
  escalateOn       String?  // "events_per_minute", "additional_events"
  threshold        Int?     // Threshold value for escalation
  occurrenceCount  Int      @default(1) // Times a matching (repo, path, category) issue has recurred while UNDER_OBSERVATION

  createdAt        DateTime @default(now())
  review           Review   @relation(fields: [reviewId], references: [id])
}

model ApprovalPrompt {
  id         String    @id @default(uuid())
  reviewId   String
  command    String    // The AWS CLI or bash command to execute
  reason     String    // Explanation presented to the human
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED, EXECUTED
  /// Set the moment the human-approved command is durably accepted for
  /// execution (POST /api/approvals/:id/execute). Distinct from updatedAt
  /// (which changes on any write): a non-null executedAt is the authoritative
  /// "this approval has been actioned" marker and the endpoint's idempotency key.
  executedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  review     Review    @relation(fields: [reviewId], references: [id])
}

model AgentMemory {
  id           String       @id @default(uuid())
  repositoryId String
  kind         String       /// "feedback", "terminology", "infra", "project"
  title        String
  body         String
  status       String       @default("active") /// "active", "archived"
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  repository   Repository   @relation(fields: [repositoryId], references: [id])

  @@index([repositoryId, status])
}

/// Latest known telemetry snapshot per (installation, provider, sourceRef) —
/// NOT a history table. Upserted every time a PR review fetches fresh
/// telemetry (see packages/webhook/src/persistence.ts persistTelemetrySnapshots),
/// so this always reflects "what we saw as of the last review", never live
/// data. Backs the dashboard's Master Grid page. Deliberately reuses
/// Postgres rather than standing up a time-series database — see
/// docs/proposal/TYME-platform-proposal.md Phase 2 for the eventual
/// OTel+ClickHouse path once real usage demands persistent history.
model TelemetrySnapshotRecord {
  id             String       @id @default(uuid())
  installationId String
  /// Telemetry provider name, e.g. "sentry" — matches TelemetryConnection.provider.
  provider       String
  /// Provider-specific scope the snapshot describes, e.g. "org/project" for
  /// Sentry or "owner/repo" for GitHub Actions. See sourceRefFor() in
  /// fetch-telemetry-context.ts for the exact per-provider format.
  sourceRef      String
  summaryText    String
  metrics        Json
  links          Json
  fetchedAt      DateTime
  createdAt      DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [id])

  @@unique([installationId, provider, sourceRef])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  installationAccess InstallationAccess[]
}

/// Durable ownership link: this User is authorized for this Installation.
/// Written at connect time (the GitHub-link callback) and write-through on a
/// successful live derivation, so login can prefer the stored row instead of
/// re-deriving the mapping from the GitHub API on every refresh (that live
/// derivation is kept only as a fallback). Fixes the connection-reset incident,
/// where a transient GitHub API failure dropped a tenant's installations.
model InstallationAccess {
  id             String       @id @default(uuid())
  userId         String
  installationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([userId, installationId])
  @@index([userId])
}

model Account {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  /// AES-256-GCM `iv:authTag:ciphertext` hex string (same format as
  /// TelemetryConnection.credentials — see lib/telemetry-credentials.ts).
  /// Only ever set for provider: 'github' rows; null for 'google'.
  githubAccessTokenEncrypted String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// A customer-registered outbound webhook destination, scoped to an
/// Installation (tenant). Areté POSTs signed `review.*` events here. The
/// `secret` is a `whsec_`-prefixed random string shown once at creation and
/// used to HMAC-sign every delivery (see packages/webhook/src/outbound/
/// signature.ts) — it is never returned by list/get endpoints and never logged.
model WebhookEndpoint {
  id             String            @id @default(uuid())
  installationId String
  /// Destination URL. Must be http(s) and is validated against the SSRF guard
  /// (packages/net-guard) at create time and again before every delivery.
  url            String
  /// `whsec_`-prefixed HMAC secret. Write-once semantics at the API layer.
  secret         String
  /// Subscribed events, a subset of ["review.created", "review.updated"].
  events         String[]
  enabled        Boolean           @default(true)
  createdAt      DateTime          @default(now())
  installation   Installation      @relation(fields: [installationId], references: [id])
  deliveries     WebhookDelivery[]

  @@index([installationId])
}

/// One delivery attempt-set for a single event to a single endpoint. `id` is
/// the value sent in the `Arete-Delivery` header and is stable across retries,
/// so the receiver can use it as an idempotency key. `attempts`/`nextAttempt`
/// drive the retry curve in packages/webhook/src/outbound/backoff.ts.
model WebhookDelivery {
  id          String          @id @default(uuid())
  endpointId  String
  event       String
  payload     Json
  /// "pending" | "delivered" | "failed"
  status      String          @default("pending")
  attempts    Int             @default(0)
  /// HTTP status of the last attempt (null if the request never got a response).
  lastCode    Int?
  /// Short error string of the last failed attempt (never contains the secret).
  lastError   String?
  /// When the next retry is due; null once delivered or permanently failed.
  nextAttempt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([status, nextAttempt])
}
