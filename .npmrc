# Cap the length of pnpm's virtual-store directory names (default 120).
# When this repo is checked out as a nested git worktree (e.g.
# .worktrees/<branch>/), the default pushes deep node_modules/.pnpm paths
# past Windows' 260-char MAX_PATH, silently producing unopenable package
# links (observed with @radix-ui/* and eslint tooling) that then fail the
# Next.js build with "Module not found".
virtual-store-dir-max-length=60
