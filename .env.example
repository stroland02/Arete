# Areté environment variables — repo root reference for all three packages
# (packages/agents, packages/webhook, packages/dashboard). Copy to `.env` and
# fill in real values; never commit real secrets. Values below are
# placeholders only.
#
# Local infra defaults (DATABASE_URL, REDIS_URL) match infra/docker-compose.yml
# (`pnpm infra:up`) and packages/db/prisma.config.ts's fallback.

# -----------------------------------------------------------------------------
# packages/agents (Python/FastAPI) — see arete_agents/config.py
# -----------------------------------------------------------------------------

# LLM Provider: "gemini" (free, dev) or "anthropic" (production)
LLM_PROVIDER=gemini

# Gemini API key -- required when LLM_PROVIDER=gemini. Get a free key at
# aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API key -- required when LLM_PROVIDER=anthropic (production)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Base URL of the packages/webhook service, reached FROM this process for the
# memory write-back: add_project_memory (arete_agents/tools/memory.py) POSTs
# to WEBHOOK_SERVICE_URL/internal/memory, which is the ONE place an
# AgentMemory row is created. Container default:
# http://webhook:3000 (docker-compose.prod.yml). Local dev: the webhook's own
# PORT, i.e. http://localhost:3000.
WEBHOOK_SERVICE_URL=http://localhost:3000

# REQUIRED for BOTH directions of agents <-> webhook traffic: this service
# mints a signed, short-lived internal token to call the webhook, and
# verifies one on its own inbound POST surface. See
# INTERNAL_TOKEN_SIGNING_KEYS / INTERNAL_TOKEN_ACTIVE_KID /
# INTERNAL_TOKEN_TTL_SECONDS, declared once further down under the internal
# auth section -- the SAME keyset JSON is set on all three processes
# (agents, webhook, dashboard); each mints with its own `iss` and verifies
# any `kid` present in the keyset:
#
#  - OUTBOUND: the memory write-back above mints an HS256 JWT
#    (`iss: "arete-agents"`) and presents it to the webhook's /internal/*
#    guard. Unset/unparseable keyset, every add_project_memory call is
#    refused by the webhook's fail-closed 503 and reports an honest failure
#    -- the feature is inert but never dishonest.
#  - INBOUND: this service's own POST surface (/review, /scan, /fix, /chat,
#    /approvals/apply, /context-map/index) verifies the same signed token
#    (arete_agents/internal_auth.py) and ALSO fails closed with 503 when the
#    keyset is unset. /review used to be fully unauthenticated, which let
#    anyone with network reach name a victim installation + repo and induce a
#    memory write into that tenant using this process's own credential.
#
# So: unset this and reviews do not run. Set the same keyset JSON everywhere.

# -----------------------------------------------------------------------------
# Shared: database + cache (packages/agents, packages/webhook, packages/dashboard)
# -----------------------------------------------------------------------------

# Postgres connection string, used by @arete/db (webhook + dashboard) and the
# agents service. Docker Compose (infra/docker-compose.yml) provides this
# locally with these exact credentials.
DATABASE_URL=postgresql://arete:arete@localhost:5432/arete

# Redis connection string, used by the agents service and by the webhook
# service's BullMQ review-job queue (packages/webhook/src/queue.ts,
# worker.ts). Docker Compose (infra/docker-compose.yml) provides this locally.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# OpenTelemetry (all services) — spec: 2026-07-20-superlog-observability §5
# -----------------------------------------------------------------------------

# OTLP/HTTP endpoint of the local collector (part of the default stack in
# infra/docker-compose.yml — `pnpm infra:up`).
# Signal paths /v1/traces, /v1/logs, /v1/metrics are appended per exporter.
# LEFT COMMENTED ON PURPOSE: unset => telemetry is a graceful no-op in every
# service (never a localhost default), which is the intended default
# experience for a fresh `cp .env.example .env`. Uncomment once the collector
# is running. The semantics are identical in @arete/telemetry (TS),
# observability.py (Python), and the dashboard's instrumentation.ts.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Comma-separated opt-in tokens. `http/dup` bridges the JS HTTP semconv
# migration (JS SDK emits legacy http.* names until v3; http/dup emits both).
# `gen_ai_latest_experimental` selects current gen_ai attribute names in the
# Python genai instrumentations (Lane B). Each SDK ignores tokens it does not
# recognize, so both live here together.
OTEL_SEMCONV_STABILITY_OPT_IN=http/dup,gen_ai_latest_experimental

# Set to "true" to run any service with telemetry fully off.
OTEL_SDK_DISABLED=

# Forced to "false" by init_observability() (Lane B, packages/agents) so the
# Traceloop-lineage instrumentors (opentelemetry-instrumentation-anthropic,
# opentelemetry-instrumentation-langchain) keep prompt/completion content OFF.
# They don't read OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT and
# default to "true" (content ON) when this is unset. Not read anywhere else;
# documented here so the contract is visible without opening observability.py.
TRACELOOP_TRACE_CONTENT=false

# deployment.environment.name resource attribute. Default: development.
# Set to "production" ONLY in production.
DEPLOYMENT_ENVIRONMENT=

# -----------------------------------------------------------------------------
# packages/webhook (TypeScript/Express) — see packages/webhook/src/config.ts
# -----------------------------------------------------------------------------

# GitHub App id (required -- the webhook server refuses to start without it)
GITHUB_APP_ID=

# GitHub App private key, PEM contents (not a file path). Literal "\n"
# sequences are unescaped to real newlines at startup, so this can be set as
# a single-line env var. (required -- the webhook server refuses to start
# without it)
GITHUB_PRIVATE_KEY=

# Secret configured on the GitHub App's webhook, used to verify inbound
# webhook signatures. (required -- the webhook server refuses to start
# without it)
GITHUB_WEBHOOK_SECRET=

# Port the webhook HTTP server listens on
PORT=3000

# Stripe secret key -- required for the /stripe-webhook route to construct a
# client; without it, Stripe billing events cannot be processed.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Secret configured on the Stripe webhook endpoint, used to verify inbound
# event signatures.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# GitLab personal/project access token used to fetch MR diffs and post review
# comments/discussions via the GitLab API.
GITLAB_ACCESS_TOKEN=glpat-your_gitlab_access_token_here

# Secret configured on the GitLab webhook (Settings > Webhooks > Secret
# Token), checked against the X-Gitlab-Token header. Required for the
# /gitlab-webhook route to accept requests -- it fails closed (401) when unset.
GITLAB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Internal service-to-service auth (Phase 3) -- signed short-lived internal
# tokens for the SERVICE-TO-SERVICE surface: /internal/*, /scan/trigger,
# /fix/trigger, /staging/send, /api/approvals/:id/execute
# (packages/webhook/src/internal-auth.ts) AND the packages/agents POST surface
# (/review, /scan, /fix, /chat, /approvals/apply, /context-map/index --
# arete_agents/internal_auth.py). Replaces the retired single-literal
# INTERNAL_API_TOKEN with a keyed, rotatable, EXPIRING credential -- see
# packages/internal-token (TS) / arete_agents/internal_token.py (Python).
# -----------------------------------------------------------------------------

# JSON object mapping kid -> secret, e.g. {"2026-07-a":"<hex secret>"}. One
# entry in steady state; TWO during a rotation window (old + new kid both
# present so tokens already signed with the old kid keep verifying). This is
# ONE value, generated once and fanned out identically into all three
# processes' environments (packages/agents, packages/webhook,
# packages/dashboard) — exactly like the retired INTERNAL_API_TOKEN was a
# single shared literal, except this is a keyed JSON object instead of a bare
# string. Each process mints its own signed HS256 JWT (`iss` = its own
# service name) using the ACTIVE kid's secret, and verifies any kid present
# in this object. Treat it as a WRITE CREDENTIAL. Every guard FAILS CLOSED
# (503) when this is empty/unparseable/unset, so those routes — reviews
# included — are unusable until it is. Generate a new kid's secret with
# `openssl rand -hex 32`. Rotation/revocation runbook:
# docs/ops/internal-token-rotation.md.
INTERNAL_TOKEN_SIGNING_KEYS=

# Which kid in INTERNAL_TOKEN_SIGNING_KEYS newly minted tokens are signed
# with. Must name a key present in the JSON object above; if it does not, the
# keyset is treated as unconfigured (503).
INTERNAL_TOKEN_ACTIVE_KID=

# Token lifetime in seconds. Defaults to 120
# (INTERNAL_TOKEN_DEFAULT_TTL_SECONDS, packages/internal-token/src/mint.ts)
# when unset -- uncomment only to override.
# INTERNAL_TOKEN_TTL_SECONDS=120

# -----------------------------------------------------------------------------
# Alerting -- Prometheus/Alertmanager -> the webhook service's incident receiver
# (packages/webhook/src/alerting/receiver.ts, infra/alertmanager.yml)
# -----------------------------------------------------------------------------

# Dedicated, SEPARATE static bearer for the ONE hop we don't originate:
# Alertmanager -> webhook POST /alerts/incoming
# (packages/webhook/src/alertmanager-auth.ts). Alertmanager cannot mint a
# signed internal token — it only ever presents a fixed string sourced from a
# `credentials_file` — so this route does NOT accept the
# INTERNAL_TOKEN_SIGNING_KEYS keyset above; it accepts ONLY this value.
# Provisioned in exactly two places, nowhere else:
#   - the webhook (to verify the presented bearer)
#   - Alertmanager itself (to present it — infra/docker-compose.yml
#     materializes it as the `alertmanager_ingest_token` Compose secret, which
#     infra/alertmanager.yml loads via `credentials_file`)
# FAILS CLOSED (503) when unset. Generate with `openssl rand -hex 32`.
ALERTMANAGER_INGEST_TOKEN=

# TRANSITIONAL FALLBACK. The uuid of the Installation row that every incoming
# alert is attributed to, and that may view Areté's own internal telemetry.
#
# ===> `Installation.isPlatform` IS NOW AUTHORITATIVE. <===
# Who the platform installation is is a DATABASE FACT: exactly one Installation
# row carries `isPlatform = true`, resolved in one place by
# packages/dashboard/src/lib/platform-installation.ts. This env var is consulted
# ONLY while NO row carries the flag, and it logs once telling you to migrate.
# Set the flag on your platform-owned Installation row, confirm the surface
# still works, then delete this var. Full rationale:
# docs/superpowers/specs/2026-07-22-telemetry-tenancy-contract.md §2.
#
# Why the flag replaced the string: a value in an env file can be mistyped into
# a CUSTOMER's installation id, and nothing would notice -- that customer would
# then receive Areté's platform alerts AND see Areté's internal errors and
# signals. A flagged row is a deliberate, auditable, single act. (This file used
# to say "There is no 'platform' flag on the Installation model to enforce
# this." That is no longer true.)
#
# Alerts are PLATFORM-WIDE: all three shipped rules (AreteReviewErrorRate,
# AreteReviewLatencyP95, AreteQueueFailureRate -- infra/prometheus-rules/) are
# about Areté's own pipeline health and carry no tenant label. The receiver
# therefore takes tenancy from the resolved platform installation ALONE and
# ignores any `installationId` label on the wire: the alert body is chosen by
# whoever can reach Alertmanager, so trusting a label there would let a
# fabricated alert file an incident -- and open a fix run -- against any
# customer.
#
# Point it at a DEDICATED, PLATFORM-OWNED Installation, NEVER a customer's.
# Incidents filed here are visible on that installation's dashboard, and a
# `critical` one opens a WorkItem against it. A mistake is made detectable
# rather than silent: an id matching no Installation drops every alert with an
# explicit error, and the resolved installation's owner is logged once at
# startup ("ALL incoming alerts are filed against this installation") so you
# can see whose account is receiving them.
#
# FAIL CLOSED, ALWAYS: no flagged row and no value here => nobody is the
# platform installation. Every incoming alert is logged and DROPPED (the
# alerting chain is inert) and the self-telemetry surfaces show nothing to
# ANYONE, including the platform's own operators. More than one flagged row is
# a misconfiguration and also resolves to nobody, loudly -- never to a guess.
# That is deliberate: losing a platform alert, or the internal error list, is
# recoverable; filing an alert against an arbitrary customer, or showing them
# Areté's internals, is not.
ARETE_PLATFORM_INSTALLATION_ID=

# OPTIONAL, off by default. The `superlog.project_id` resource attribute stamped
# onto Areté's OWN telemetry -- its spans, logs and exceptions -- by
# packages/telemetry/src/resource.ts, the dashboard's src/instrumentation.ts and
# arete_agents/observability.py.
#
# MUST equal the flagged platform installation (the `isPlatform` row above).
# This is self-DOGFOODING tagging, NOT tenant data: nothing ingests customer
# telemetry yet (that is Phase 3 --
# docs/roadmap/2026-07-15-superlog-phased-roadmap.md), so every row in
# superlog.otel_traces / otel_logs / otel_exceptions comes from Areté's own
# services. The value answers exactly one question: under which installation
# should Areté's own telemetry be visible?
#
# If this and the platform installation ever DIVERGE, Areté's own spans are
# stamped with one installation's id while the access gate authorizes another --
# which is precisely how Areté's internals end up in someone else's Signals
# panel. `assertSelfTelemetryTenancyConsistent`
# (packages/dashboard/src/lib/platform-installation.ts) compares the two on the
# read path and logs a SELF-TELEMETRY TENANCY MISMATCH rather than tolerating it
# silently. NEVER point this at a real customer tenant in prod.
#
# Note it is NOT the access control: reads gate on `isPlatformInstallation`
# first and treat the project_id filter as partitioning only (telemetry-tenancy
# contract §3). UNSET => Areté's telemetry carries no project_id and the
# self-telemetry reads simply match nothing. scripts/dev/dev-all.mjs defaults it
# to the local dev installation id for local dogfooding.
ARETE_SELF_PROJECT_ID=

# Base URL of the GitLab instance to call. Defaults to https://gitlab.com;
# override for self-hosted GitLab.
GITLAB_URL=https://gitlab.com

# Base URL of the packages/agents FastAPI service that runs the actual review
# pipeline. Defaults to http://127.0.0.1:8000 for local dev.
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# 64-character hex string (32 bytes) — AES-256-GCM key for encrypting
# telemetry connector credentials (e.g. PostHog API keys) at rest.
# Generate with: openssl rand -hex 32
# Must be the SAME value in the dashboard's env too -- dashboard writes
# API-key connections (e.g. Stripe), webhook decrypts and uses them.
TELEMETRY_ENCRYPTION_KEY=

# OAuth connector app credentials (per provider) — only required once that
# provider's "Connect" flow is used. Register the app in each provider's
# developer console (Vercel Integrations Console, PostHog OAuth app settings)
# and set the redirect URI there to {OAUTH_REDIRECT_BASE_URL}/oauth/<provider>/callback.
OAUTH_REDIRECT_BASE_URL=
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
POSTHOG_OAUTH_CLIENT_ID=
POSTHOG_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# packages/dashboard (Next.js) — see packages/dashboard/src/lib/db.ts
# -----------------------------------------------------------------------------
# Uses DATABASE_URL above (required -- the dashboard throws at startup if it
# is unset).

# Dashboard login (Auth.js / NextAuth v5) -- Areté accounts: email+password
# (Credentials) plus "Continue with Google". Create a Google OAuth client at
# https://console.cloud.google.com/apis/credentials with redirect URI
# {origin}/api/auth/callback/google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Session/JWT signing secret -- generate with `openssl rand -base64 33`
AUTH_SECRET=your_auth_secret_here

# Webhook service's own base URL -- the dashboard links into its OAuth
# authorize routes (GET /oauth/:provider/authorize) for the Connect flow.
# Local dev default matches the webhook service's own PORT (3000) above.
WEBHOOK_SERVICE_URL=http://localhost:3000

# DEPRECATED (removed): GITHUB_OAUTH_CLIENT_ID / GITHUB_OAUTH_CLIENT_SECRET --
# GitHub is no longer a dashboard *login* provider; GitHub linking moves to
# the Connections page in a future integration. (The GITHUB_APP_* vars above
# for packages/webhook are unrelated and still required.)

# "Connect GitHub" account-link flow (packages/dashboard/src/lib/github-link.ts)
# -- a SEPARATE, dedicated GitHub OAuth App (Settings -> Developer settings ->
# OAuth Apps), distinct from both the Areté GitHub App above and any dashboard
# login provider. Lets an already-signed-in dashboard user (Google/Credentials)
# link their GitHub identity so session.installations can be resolved. Set the
# OAuth App's callback URL to {GITHUB_LINK_REDIRECT_BASE_URL}/api/github-link/callback.
GITHUB_LINK_CLIENT_ID=
GITHUB_LINK_CLIENT_SECRET=
GITHUB_LINK_REDIRECT_BASE_URL=

# Jaeger UI base URL -- OPTIONAL. Turns the trace ids the dashboard already
# holds into "Trace" deep-links (`{base}/trace/{traceId}`) on the Errors list
# and on an incident's Signals rows, so an error can be opened as the trace
# that produced it. See packages/dashboard/src/lib/trace-links.ts.
#
# Leaving it UNSET is a supported state, not a broken one: no link is rendered
# anywhere -- not a greyed-out one, not a dead anchor -- and the trace ids are
# still shown as plain text. Nothing else changes.
#
# NEXT_PUBLIC_ is required, not decoration: the Errors list is a client
# component, and Next only inlines an env var into the browser bundle when it
# carries that prefix (same pattern as NEXT_PUBLIC_GLASSBOX_URL). It is
# inlined at BUILD time, so set it before `next build`, and only ever put a
# non-secret value here -- it ships to the browser.
#
# Local dev (infra/docker-compose.yml maps Jaeger's UI to 16686):
#   NEXT_PUBLIC_JAEGER_UI_URL=http://localhost:16686
# Only http:// and https:// bases are accepted; anything else is ignored and
# the links stay hidden.
NEXT_PUBLIC_JAEGER_UI_URL=

# ---------------------------------------------------------------------------
# BUILD_STATUS_EDITABLE -- OPTIONAL, local development only.
#
# Set to `1` to let /build-status add, amend and remove items from
# docs/roadmap/master-build-status.json (and regenerate its markdown view)
# straight from the browser.
#
# It writes files INSIDE the repository, so it is a development affordance, not
# a tenant feature. The route is fail-closed twice over: it needs a session AND
# this flag AND a non-production NODE_ENV. Setting it in a production
# environment does nothing -- see packages/dashboard/src/lib/build-status/store.ts.
#
# Leaving it UNSET is a supported state: the page renders read-only and the
# edit control is shown DISABLED with the reason, never hidden.
BUILD_STATUS_EDITABLE=
